# ===== TELEGRAM =====
# Token bot dari @BotFather
BOT_TOKEN=123456:ABC-DEF_yourtokenhere

# ID Telegram admin (boleh lebih dari satu, pisah dengan koma)
# Cek ID kamu dengan mengetik /id ke bot
ADMIN_IDS=123456789

# Telegram App credentials dari https://my.telegram.org (untuk Local Bot API)
# Sudah diisi (akun bot khusus). Ganti kalau pakai akun lain.
TELEGRAM_API_ID=32773999
TELEGRAM_API_HASH=d2eb7260911dbce615a1fb27f36d4b12

# Alamat Local Bot API server (jalankan via Docker aiogram/telegram-bot-api).
# Kosongkan untuk memakai server resmi Telegram (https://api.telegram.org).
BOT_API_ROOT=http://localhost:8081

# ===== REDIS (cache session) =====
# Kosongkan untuk fallback ke session in-memory.
REDIS_URL=redis://127.0.0.1:6379

# ===== POSTGRESQL =====
# install.sh meng-generate password & DATABASE_URL otomatis.
DATABASE_URL=postgres://ppob:GANTI_PASSWORD_KUAT@127.0.0.1:5432/ppob
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=ppob
PGPASSWORD=GANTI_PASSWORD_KUAT
PGDATABASE=ppob

# ===== BACKUP =====
# Token bot KHUSUS backup (dari @BotFather, beda dari BOT_TOKEN jualan).
# File backup harian dikirim lewat bot ini. Kosongkan untuk fallback ke BOT_TOKEN.
BACKUP_BOT_TOKEN=
# ID chat/channel tujuan backup. WAJIB start/chat dulu bot backup-nya,
# lalu isi ID kamu (lihat /id) atau ID channel privat (bot backup jadi admin).
BACKUP_CHAT_ID=
# Password ZIP backup (di-generate otomatis oleh install.sh kalau kosong).
# Dipakai untuk membuka file .zip backup. SIMPAN baik-baik!
BACKUP_ZIP_PASSWORD=

# ===== DIGIFLAZZ (provider PPOB) =====
DIGIFLAZZ_USERNAME=your_digiflazz_username
DIGIFLAZZ_API_KEY=your_digiflazz_dev_or_prod_key
DIGIFLAZZ_MODE=prepaid
# Rekonsiliasi status transaksi Pending (poller). Interval cek (detik), 0 = nonaktif.
DIGIFLAZZ_RECONCILE_SEC=60
# Transaksi yang masih Pending > sekian menit dianggap GAGAL & saldo di-refund. 0 = jangan auto-gagalkan.
DIGIFLAZZ_RECONCILE_TIMEOUT_MIN=30

# ===== TOP UP / DEPOSIT =====
TOPUP_INFO=BCA 1234567890 a.n. RAYZELL STORE
MIN_TOPUP=10000

# ===== ANTI-DOBEL ORDER =====
# Cegah double-charge bila pembeli menekan "beli" berkali-kali. Pembelian
# produk+nomor yang sama oleh user yang sama ditolak bila masih diproses
# (Pending) ATAU baru saja SUKSES dalam sekian detik terakhir. Yang GAGAL tidak
# menghalangi (boleh coba lagi). 0 = nonaktifkan cooldown (yang Pending tetap diblokir).
ORDER_DEDUP_SEC=120

# ===== QRIS (AutoGoPay) =====
# API Key dari dashboard AutoGoPay. Kosongkan untuk menonaktifkan fitur QRIS.
AUTOGOPAY_API_KEY=
AUTOGOPAY_BASE_URL=https://v1-gateway.autogopay.site
# Fee QRIS yang ditanggung member (bukan kamu). flat = rupiah, percent = persen.
QRIS_FEE_TYPE=flat
QRIS_FEE_VALUE=0
# Pembulatan total ke atas (kelipatan). 0 = tidak membulatkan.
QRIS_FEE_ROUND=100
# Interval cek pembayaran (detik) & berapa lama notif sukses bertahan sebelum dihapus.
QRIS_POLL_INTERVAL_SEC=3
QRIS_SUCCESS_TTL_SEC=15

# ===== TAMPILAN =====
STORE_NAME=Rayzell Store PPOB
MAINTENANCE_INFO=23:00 - 00:30 WIB
BOT_VPN_URL=https://t.me/your_vpn_bot
ADMIN_CONTACT=https://t.me/your_admin_username

# ===== NOTIF TRANSAKSI KE GRUP =====
# ID grup PRIVATE (detail lengkap, untuk monitoring admin). Kosong = tidak kirim.
# ID grup PUBLIC (versi disensor, hanya transaksi sukses). Kosong = tidak kirim.
# Cara dapat ID grup: tambahkan bot ke grup, kirim pesan, cek update/pakai @userinfobot.
# ID grup biasanya diawali tanda minus, contoh: -1001234567890
TRX_GROUP_PRIVATE_ID=
TRX_GROUP_PUBLIC_ID=


# ===== WEB STOREFRONT =====
WEB_PORT=3000
PUBLIC_URL=https://rayzelldigital.web.id
CONTACT_WA=087826532525
CONTACT_TG=https://t.me/Rayzell23
# Username bot jualan tanpa @, WAJIB untuk Login Telegram di web (juga dipakai tombol "Beli"). Kosong = pakai CONTACT_TG.
BOT_USERNAME=

# ===== ADMIN WEB =====
# Login admin panel via email + password (atau username + password)
# WAJIB diganti sebelum production!
WEB_ADMIN_EMAIL=admin@rayzell.id
WEB_ADMIN_USER=admin
WEB_ADMIN_PASSWORD=admin123

# ===== LOGIN GOOGLE (opsional) =====
# Isi ketiganya untuk mengaktifkan tombol "Masuk dengan Google" di web.
# Buat di Google Cloud Console -> Credentials -> OAuth client ID (Web application).
# Authorized redirect URI di Google HARUS sama persis dengan GOOGLE_REDIRECT_URI di bawah.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://rayzelldigital.web.id/api/auth/google/callback
